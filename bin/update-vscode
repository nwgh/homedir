#!/usr/bin/env python

import functools
import os
import requests
import shutil
import signal
import subprocess
import sys
import time


def log_console(msg):
    sys.stdout.write('%s\n' % (msg,))


def log_file(outfile, msg):
    with file(outfile, 'a') as f:
        f.write('%s\n' % (msg,))


def log_null(msg):
    pass


def parent_notify():
    log_console('Restarting vs code...')
    time.sleep(5)


class VSCodeUpdater(object):
    def __init__(self):
        self.update_url = 'https://vscode-update.azurewebsites.net/latest/linux-x64/insider'

        self.home = os.getenv('HOME')
        self.vscode_root = os.path.join(self.home, '.local', 'vscode')
        self.md5_file = os.path.join(self.vscode_root, 'current-md5')
        self.output_file = os.path.join(self.vscode_root, 'code.tgz')
        self.log_file = os.path.join(self.vscode_root, 'update.log')
        self.install_dir = os.path.join(self.vscode_root, 'VSCode-linux-x64')
        self.previous_install_dir = self.install_dir + '-previous'
        self.vscode_exe = os.path.join(self.install_dir, 'code-insiders')

        self.logtype = 'console' # Other options are 'file' and 'null'
        self.logfuncs = {
            'console': log_console,
            'file': functools.partial(log_file, self.log_file),
            'null': log_null
        }


    def log(self, msg):
        assert self.logtype in self.logfuncs
        self.logfuncs[self.logtype](msg)


    def die(self, msg, code=1):
        self.log(msg)
        sys.exit(code)


    def bg_continue(self, use_logfile, parent_cb, wait_time):
        # This is being run from vs code, so now we need to do some fun things
        # to be able to automatically restart
        try:
            pid = os.fork()
        except:
            self.die('Failed to background, try again from the shell.')

        if not pid:
            # Parent process
            if parent_cb:
                parent_cb()
            sys.exit(0)

        # If we get here, we're in the child process.
        os.setsid()
        if wait_time:
            time.sleep(wait_time) # Give the parent time to finish up

        if use_logfile:
            if os.path.exists(self.log_file):
                # Start the log file afresh
                os.unlink(self.log_file)
            self.logtype = 'file'
        else:
            self.logtype = 'null'


    def main(self):
        vscode_procs = None

        try:
            self.log('Checking for running VS Code...')
            vscode_procs = subprocess.check_output(
                    ['pgrep', 'code-insiders'], stderr=subprocess.PIPE)
        except subprocess.CalledProcessError:
            pass

        restart_vscode = False

        if vscode_procs:
            restart_vscode = True
            self.log('Visual Studio Code appears to still be running. '
                     'Will try to restart it for you.')

        if not os.path.exists(self.vscode_root):
            self.die('VS Code root missing: %s' % (self.vscode_root,))
        self.log('VS Code root: %s' % (self.vscode_root,))

        # See if we have an update available
        self.log('Checking for update...')

        response = requests.head(self.update_url, allow_redirects=True)
        content_md5 = None
        if response.status_code == 200:
            content_md5 = response.headers['content-md5']

        if not content_md5:
            self.die('No update (MD5 missing)')

        current_md5 = file(self.md5_file).read().strip()
        if current_md5 == content_md5:
            self.die('No update available', code=0)

        # Download the new tarball
        self.log('Downloading new tarball...')
        response = requests.get(self.update_url)
        if response.status_code != 200:
            self.die('Error downloading %s' % (self.update_url,))

        with file(self.output_file, 'w') as f:
            f.write(response.content)

        bg_restart = False

        vscode_pid = int(os.getenv('VSCODE_PID', '0'))
        if vscode_pid:
            # THE CALL IS COMING FROM INISDE THE HOUSE!
            # No, really though, this is being run from inside VS Code, so we
            # have to background ourself before we kill vs code to continue.
            self.bg_continue(True, parent_notify, 15)
        elif vscode_procs:
            vscode_pid = sorted(map(int, vscode_procs.strip().split('\n')))[0]
            bg_restart = True

        if vscode_pid:
            # OK, kill vs code so we can carry on
            self.log('Killing vs code...')
            os.kill(vscode_pid, signal.SIGTERM)

        # Move our current installation out of the way, keeping one backup
        self.log('Backing up current version...')
        if os.path.exists(self.install_dir):
            if os.path.exists(self.previous_install_dir):
                shutil.rmtree(self.previous_install_dir)
            shutil.move(self.install_dir, self.previous_install_dir)

        self.log('Unpacking new version...')
        rv = subprocess.call(
                ['tar', '-C', self.vscode_root, '-xzf', self.output_file],
                stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        if rv != 0:
            # Restore our current version
            if os.path.exists(self.previous_install_dir):
                shutil.move(self.previous_install_dir, self.install_dir)
            self.die('Error unpacking %s' % (self.output_file,))

        self.log('Updating md5...')
        with file(self.md5_file, 'w') as f:
            f.write(content_md5)

        if bg_restart:
            self.bg_continue(False, None, 0)

        if restart_vscode:
            self.log('Restarting vs code...')
            os.execl(self.vscode_exe, self.vscode_exe)

updater = VSCodeUpdater()
updater.main()
